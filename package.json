{
  "name": "@caeher/react-tiptap-editor",
  "version": "1.5.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./style": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite playground",
    "playground": "vite playground",
    "build": "tsup && node -e \"require('fs').copyFileSync('src/components/editor/editor.css', 'dist/index.css')\"",
    "build:playground": "vite build playground",
    "preview": "vite preview playground",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caeher/react-tiptap-editor.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
